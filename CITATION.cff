  type: article
  authors:
    - family-names: "Ajayi"
      given-names: "Imoleayomide"
  title: "From SEM Image to Particle Size Report: A Practical Primer on Automated Segmentation, Multi-Technique Size Comparison, and Metrologically Traceable Uncertainty Quantification"
  journal: "Journal of Microscopy"
  year: 2025
  notes: "Primers in Microscopy special issue (submitted)"
